// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Barbershop {
  id          String   @id @default(uuid())
  name        String
  document    String?  // CNPJ or CPF
  phone       String?
  address     String?
  isActive        Boolean  @default(true)
  subscriptionFee Decimal  @default(0.00) @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  slug            String?  @unique
  logoUrl         String?
  welcomeMessage  String?

  users        User[]
  customers    Customer[]
  services     Service[]
  appointments Appointment[]
  products     Product[]
  sales        ProductSale[]
  transactions FinancialTransaction[]
  schedules    WorkSchedule[]
  blockedTimes BlockedTime[]
  settings     Settings?
}

enum Role {
  SUPER_ADMIN
  BARBER
  EMPLOYEE
  RECEPTIONIST
}

model User {
  id           String      @id @default(uuid())
  barbershopId String?
  barbershop   Barbershop? @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  name         String
  email        String      @unique
  password     String
  role         Role        @default(BARBER)
  phone        String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  appointments Appointment[]
  schedules    WorkSchedule[]
  blockedTimes BlockedTime[]
  auditLogs    AuditLog[]
}

model Customer {
  id           String     @id @default(uuid())
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  name         String
  email        String?
  phone        String
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  appointments Appointment[]
  purchases    ProductSale[]
}

model Service {
  id           String     @id @default(uuid())
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  price        Decimal    @db.Decimal(10, 2)
  duration     Int        // Duration in minutes
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  appointments Appointment[]
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELED
  NO_SHOW
}

model Appointment {
  id           String            @id @default(uuid())
  barbershopId String
  barbershop   Barbershop        @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  customerId   String
  customer     Customer          @relation(fields: [customerId], references: [id])
  userId       String            // The barber
  user         User              @relation(fields: [userId], references: [id])
  serviceId    String
  service      Service           @relation(fields: [serviceId], references: [id])
  
  date         DateTime          // Scheduled date and time
  status       AppointmentStatus @default(PENDING)
  notes        String?
  
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?
}

model Product {
  id           String     @id @default(uuid())
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  imageUrl     String?    // Image URL for the product
  price        Decimal    @db.Decimal(10, 2)
  stock        Int        @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  sales        ProductSale[]
}

model ProductSale {
  id           String     @id @default(uuid())
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  customerId   String?
  customer     Customer?  @relation(fields: [customerId], references: [id])
  
  quantity     Int
  totalPrice   Decimal    @db.Decimal(10, 2)
  saleDate     DateTime   @default(now())
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
}

enum TransactionType {
  INCOME
  EXPENSE
}

model FinancialTransaction {
  id           String          @id @default(uuid())
  barbershopId String
  barbershop   Barbershop      @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  type         TransactionType
  amount       Decimal         @db.Decimal(10, 2)
  description  String
  date         DateTime        @default(now())
  
  // Optional relations to track source
  appointmentId String?
  saleId        String?
  
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?
}

model WorkSchedule {
  id           String     @id @default(uuid())
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  
  dayOfWeek    Int        // 0 = Sunday, 1 = Monday, etc.
  startTime    String     // e.g., "09:00"
  endTime      String     // e.g., "18:00"
  breakStart   String?    // e.g., "12:00"
  breakEnd     String?    // e.g., "13:00"
  
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model BlockedTime {
  id           String     @id @default(uuid())
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  userId       String?    // Optional: if null, blocks entire shop
  user         User?      @relation(fields: [userId], references: [id])
  
  startTime    DateTime
  endTime      DateTime
  reason       String?
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Settings {
  id           String     @id @default(uuid())
  barbershopId String     @unique
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  
  openingTime  String     @default("09:00")
  closingTime  String     @default("19:00")
  slotDuration Int        @default(30) // in minutes
  
  automations  Json?      // Store automation toggles e.g., { reminder24h: true }
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model AuditLog {
  id           String     @id @default(uuid())
  action       String     // e.g., "LOGIN", "DELETE_USER"
  entity       String     // e.g., "User", "Barbershop"
  entityId     String?
  userId       String?
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  details      String?    // JSON string for additional details
  ipAddress    String?
  
  createdAt    DateTime   @default(now())
}

model PlatformSettings {
  id           String     @id @default(uuid())
  name         String     @default("Meu Barbeiro")
  theme        String     @default("dark")
  monthlyFee   Decimal    @default(99.90) @db.Decimal(10, 2)
  isActive     Boolean    @default(true)
  
  updatedAt    DateTime   @updatedAt
}
